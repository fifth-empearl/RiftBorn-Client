  UIWidget
    id : slotFour
    image-source: images/emptySlotBBg
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: slotThree.right
    margin-left: 30
    margin-top: 10
    size: 90 90
    image-color: white
    UIItem
      id: slotSprite
      item-id: 
      anchors.centerIn: parent
      size: 32 32
      virtual: true

  Label
    id: RuneWord
    anchors.horizontalCenter: parent.horizontalCenter
    anchors.bottom: parent.bottom
    margin-bottom: 20
    text:

  UIButton
