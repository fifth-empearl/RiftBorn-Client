    image-source: images/selectedSlotBBg
    anchors.top: parent.top
    anchors.right: parent.horizontalCenter
    margin-top: 10
    margin-right: 10
    size: 90 90
    image-color: white
    UIItem
      id: runeTwoSprite
      item-id: 
      anchors.centerIn: parent
      size: 32 32
      virtual: true

  UIWidget
    id : runeWordRuneThreeEntry
    image-source: images/selectedSlotBBg
    anchors.top: parent.top
    anchors.left: parent.horizontalCenter
    margin-top: 10
    margin-left: 10
    size: 90 90
    image-color: white
    UIItem
      id: runeThreeSprite
      item-id: 
      anchors.centerIn: parent
      size: 32 32
      virtual: true

  UIWidget
    id : runeWordRuneFourEntry
    image-source: images/selectedSlotBBg
    anchors.top: parent.top
    anchors.left: runeWordRuneThreeEntry.right
    margin-top: 10
    margin-left: 20
    size: 90 90
    image-color: white
    UIItem
      id: runeFourSprite
