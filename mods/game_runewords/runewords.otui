  UIWidget
    id : slotThree
    image-source: images/emptySlotBBg
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: parent.horizontalCenter
    margin-left: 15
    margin-top: 10
    size: 90 90
    image-color: white
    UIItem
      id: slotSprite
      item-id: 
      anchors.centerIn: parent
      size: 32 32
      virtual: true

  CheckBoxCircle
    id: slotFourCheck
    anchors.top: slotFour.top
    anchors.horizontalCenter: slotFour.horizontalCenter
