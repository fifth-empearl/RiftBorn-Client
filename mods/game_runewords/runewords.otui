    UIItem
      id: slotSprite
      item-id: 
      anchors.centerIn: parent
      size: 32 32
      virtual: true

  CheckBoxCircle
    id: slotThreeCheck
    anchors.top: slotThree.top
    anchors.horizontalCenter: slotThree.horizontalCenter
