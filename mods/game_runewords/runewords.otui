RuneEntry < UIWidget
  border-width: 3
  border-color: #272727
  height: 50
  image-source: images/panel-bg
  image-border: 9
  $focus:
    border-width: 1
    border-color: #f5971e

  UIItem
    id: runeSprite
    item-id: 11616
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: parent.left
    margin-left: 10
    size: 32 32
    virtual: true

  Label
    id: runeName
    text: Szu
    anchors.top: runeSprite.top
    anchors.left: runeSprite.right
    margin-left: 40
    margin-top: 2
    width: 100

  Label
    id: runeQty
    text: Quantity: 3
    anchors.top: runeName.bottom
    anchors.left: runeSprite.right
    margin-left: 30
    width: 100

RunePediaEntry < UIWidget
  border-width: 3
  border-color: #272727
  image-source: images/panel-bg
  image-border: 9

  UIWidget
    id : runeEntry
    image-source: images/fullSlotBBg
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 10
    size: 90 90
    image-color: white
    UIItem
      id: runeSprite
      item-id: 
      anchors.centerIn: parent
      size: 32 32
      virtual: true

  Label
    id: runeName
    text: Szu
    anchors.top: runeEntry.bottom
    anchors.right: parent.right
    anchors.left: parent.left
    margin-top: 10
    text-align: center
    text-auto-resize: true
    text-wrap: true

  Label
    id: runeBuff
    anchors.top: runeName.bottom
    anchors.right: parent.right
    anchors.left: parent.left
    margin-top: 0
    text-align: center
    text-auto-resize: true
    text-wrap: true

