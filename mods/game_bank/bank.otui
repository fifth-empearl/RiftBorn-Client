WithdrawWindow < StaticMainWindow
  size: 230 140
  anchors.centerIn: parent
  !text: tr("Withdraw")
  visible: false
  draggable: true

  Label
    id: currencyLabel
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 2
    font: verdana-11px-rounded
    text: Currency:
    text-auto-resize: true

  UIItem
    id: currencyIcon
    anchors.top: parent.top
    anchors.left: currencyLabel.right
    margin-left: 8
    size: 24 24
    virtual: true

  Label
    id: currencyName
    anchors.verticalCenter: currencyIcon.verticalCenter
    anchors.left: currencyIcon.right
    anchors.right: parent.right
    margin-left: 6
    text-auto-resize: false
    text-wrap: false

  Label
    id: amountLabel
    anchors.top: currencyIcon.bottom
    anchors.left: parent.left
    margin-top: 10
    font: verdana-11px-rounded
    text: Amount:
    text-auto-resize: true

  TextEdit
    id: amount
    anchors.top: amountLabel.top
    anchors.right: parent.right
    margin: 0 0 0 10
    height: 22
    width: 120
    padding-top: 3

  Button
    id: close
    width: 50
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    text: Close

  Button
    id: confirm
    width: 70
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    text: Confirm

